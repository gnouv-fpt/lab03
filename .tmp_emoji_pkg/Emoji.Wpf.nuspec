<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Emoji.Wpf</id>
    <version>0.3.4</version>
    <title>Emoji.Wpf</title>
    <authors>Sam Hocevar</authors>
    <license type="expression">WTFPL</license>
    <licenseUrl>https://licenses.nuget.org/WTFPL</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://github.com/samhocevar/emoji.wpf</projectUrl>
    <description>Emoji rendering for WPF applications</description>
    <copyright>Copyright © 2017–2021 Sam Hocevar</copyright>
    <tags>Emoji Unicode WPF XAML</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.0">
        <dependency id="JeremyAnsel.HLSL.Targets" version="1.0.13" exclude="Build,Analyzers" />
        <dependency id="Stfu" version="0.1.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETCoreApp3.1">
        <dependency id="JeremyAnsel.HLSL.Targets" version="1.0.13" exclude="Build,Analyzers" />
        <dependency id="Stfu" version="0.1.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework=".NETCoreApp3.1">
        <frameworkReference name="Microsoft.WindowsDesktop.App.WPF" />
      </group>
      <group targetFramework=".NETFramework4.0" />
    </frameworkReferences>
  </metadata>
</package>